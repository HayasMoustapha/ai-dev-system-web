OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-nano

# Optional alternative to direct OpenAI usage:
# AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key
# AI_GATEWAY_MODEL=openai/gpt-5-nano

# Public canonical site URL — used by metadata, OpenGraph images, sitemap and
# robots. Set this to the deployed domain so social/SEO absolute URLs are right.
# Defaults to https://ai-dev-system-web.vercel.app when unset.
NEXT_PUBLIC_SITE_URL=https://ai-dev-system-web.vercel.app
